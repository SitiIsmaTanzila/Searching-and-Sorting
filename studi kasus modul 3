def linear_search(arr, target):
    for i in range (len(arr)):
        if arr[i] == target:
            return -i
    return -1
data= [60, 75, 80, 85, 95]
angka_dicari = 95 #target
hasil = linear_search(data, angka_dicari)
print(data)
if hasil !=-1:
    print("angka", angka_dicari, " ada di indeks ke -", hasil)
else:
    print("angka tidak ditemukan")

print("STUDI KASUS 2")
def bubble_sort(arr):

    n = len(arr)
    for i in range(n):
        for j in range (n-i-1):
            if arr[j] > arr [j+1]:
                arr [j], arr[j+1] = arr[j+1], arr [j]
    return arr
# data yang akan diurutkan
data = [85, 70, 90, 95, 60]
#panggil fungsi
hasil = bubble_sort(data)
#tampilkan hasil
print ("Data sebelum sorting:", [85, 70, 90, 95, 60 ])
print("Data setelah sorting:", hasil)

